      "sparql": "PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>\nPREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>\nPREFIX owl: <http://www.w3.org/2002/07/owl#>\nPREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\nPREFIX corp: <http://example.org/corporate#>\n\nSELECT ?entity ?type\nWHERE {\n  {\n    ?entity a owl:Class .\n    BIND(\"Class\" AS ?type)\n  }\n  UNION\n  {\n    ?entity a owl:ObjectProperty .\n    BIND(\"ObjectProperty\" AS ?type)\n  }\n  UNION\n  {\n    ?entity a owl:DatatypeProperty .\n    BIND(\"DatatypeProperty\" AS ?type)\n  }\n  UNION\n  {\n    ?entity a ?class .\n    FILTER(?class IN (corp:Company, corp:Department, corp:Employee, corp:Manager, corp:Engineer, corp:Project, corp:Client, corp:Office)) .\n    BIND(\"Individual\" AS ?type)\n  }\n}\nORDER BY ?type ?entity"
